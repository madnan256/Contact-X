modules = ["nodejs-20", "web", "dotnet-8.0"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && API_PORT=3001 dotnet run --no-build --urls http://0.0.0.0:3001"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-lc", "cd backend && API_PORT=5000 dotnet ./publish/ContactsX.Api.dll --urls http://0.0.0.0:5000"]
build = ["bash", "-lc", "cd frontend && npm install && npm run build && rm -rf ../backend/wwwroot && mkdir -p ../backend/wwwroot && cp -r dist/* ../backend/wwwroot/ && cd ../backend && dotnet publish -c Release -o ./publish"]
